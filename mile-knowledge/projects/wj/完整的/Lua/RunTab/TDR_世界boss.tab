/cmd CreateEmptyFile("perfeye_start")	5	采集数据
/cmd CreateEmptyFile("WorldBoss")	10	启动用例
/cmd CreateEmptyFile("perfeye_stop")	20	结束采集
/cmd CreateEmptyFile("ExitGame")	2	结束游戏