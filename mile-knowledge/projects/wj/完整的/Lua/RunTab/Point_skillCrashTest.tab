CommandName	WaitTime	Description
/cmd CreateEmptyFile("BeginRunMap")	20	开始跑图
/gm player.SwitchMap(2,88532, 41185, 1116608)	30	切换地图
/cmd QualityMgr.SetQualityByType(GameQualityType._video_)	5	设置画质
/cmd QualityMgr.SetQualityByType(GameQualityType._video1_)	10	切换原本画质
/gm player.SetPosition(88532, 41185, 1116608)	20	传送
/cmd SearchPanel.SetCustomOptions("同屏玩家数",15)	5	设置同屏玩家数为15
/cmd TurnTo(32)	1	转动视角
/cmd TurnToFaceDirection()	1	调整摄像机角度正对人物
/cmd CreateEmptyFile("skilltest_start")	10	开启测试