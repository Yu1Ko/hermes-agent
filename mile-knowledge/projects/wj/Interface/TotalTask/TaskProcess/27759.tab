Sleep=10
[回去交任务对话]
Btn=Event.Dispatch(EventType.OnSceneInteractByHotkey,false)
[点击任务]
Btn=UINodeControl.BtnTrigger('BtnContent_1')
[交付任务]
Btn=UINodeControl.BtnTrigger('BtnOperation')
[接受新的任务]
Btn=UINodeControl.BtnTrigger('BtnOperation')
[缓冲任务时间]
Sleep=10
[缓冲任务时间]
Sleep=5
[结束]