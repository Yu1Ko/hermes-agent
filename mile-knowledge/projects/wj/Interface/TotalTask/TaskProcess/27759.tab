[送果干]
Btn=AutoRoadWay.Start(158672,188208,1308608)
Sleep=10
[特殊对话]
Btn=Event.Dispatch(EventType.OnSceneInteractByHotkey,false)
[交付饮品]
Btn=UINodeControl.BtnTrigger('BtnContent_1')
[关闭面板]
Btn=UINodeControl.BtnTrigger("BtnCloseRight")
[自动寻路]
