/cmd QualityMgr.SetQualityByType(GameQualityType._video_)	5	设置画质
/cmd QualityMgr.SetQualityByType(GameQualityType._video1_)	10	切换原本画质
/cmd DungeonApi.SetMapName("獭山岛")	5	设置对应的副本
/cmd PlayerAuto.SetAttackTimeCount(5)	5	设置打斗时间
/cmd CreateEmptyFile("perfeye_start")	10	采集数据
/gm player.SwitchMap(15,30707,30154,1067264)	30	传送长安指定地点
/cmd TurnTo(244)	10	转动视角
/cmd TurnToFaceDirection()	10	调整摄像机角度正对人物
/cmd SetCameraStatus(1083,1,3,-0.1369)	10	右
/cmd SetCameraStatus(1083,1,4.4,-0.1369)	10	下
/cmd SetCameraStatus(1083,1,6.6,-0.1369)	10	左
/cmd SetCameraStatus(1083,1,8.0,-0.1369)	10	上
/cmd CreateEmptyFile("Test")	60	等待1分钟
/gm player.SwitchMap(726,9871,12321,1048896)	30	传送前置条件
/gm player.SetPosition(9871,12321,1048896)	10	传送剧情
/cmd CreateEmptyFile("Dungeons")	10	启动副本
/gm player.SwitchMap(15,30707,30154,1067264)	30	传送长安指定地点
/cmd TurnTo(244)	10	转动视角
/cmd TurnToFaceDirection()	10	调整摄像机角度正对人物
/cmd SetCameraStatus(1083,1,3,-0.1369)	10	右
/cmd SetCameraStatus(1083,1,4.4,-0.1369)	10	下
/cmd SetCameraStatus(1083,1,6.6,-0.1369)	10	左
/cmd SetCameraStatus(1083,1,8.0,-0.1369)	10	上
/cmd CreateEmptyFile("Test")	60	等待1分钟
